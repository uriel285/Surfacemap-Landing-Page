{
  "name": "surfacemap",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-scripts": "5.0.1",
    "three": "^0.184.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "tailwind:build": "tailwindcss -i ./src/input.css -o ./src/index.css",
    "tailwind:watch": "tailwindcss -i ./src/input.css -o ./src/index.css --watch",
    "start": "npm run tailwind:build && concurrently \"npm run tailwind:watch\" \"react-scripts start\"",
    "build": "react-scripts build"
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17"
  }
}
